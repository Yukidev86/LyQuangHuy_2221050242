@model List<DemoMvc.Models.SinhVien>

<h2>Danh sách sinh viên</h2>

<a href="/SinhVien/Create">Thêm sinh viên</a>

<table border="1">
<tr>
    <th>ID</th>
    <th>Mã sinh viên</th>
    <th>Họ tên</th>
    <th>Chức năng</th>
</tr>

@foreach (var item in Model)
{
<tr>
    <td>@item.Id</td>
    <td>@item.MaSinhVien</td>
    <td>@item.HoTen</td>
    <td>
        <a href="/SinhVien/Edit/@item.Id">Edit</a>
        <a href="/SinhVien/Delete/@item.Id">Delete</a>
    </td>
</tr>
}

</table>