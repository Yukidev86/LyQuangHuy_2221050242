@model DemoMvc.Models.SinhVien

<h2>Xoá sinh viên</h2>

<h4>Bạn có chắc muốn xoá sinh viên này?</h4>

<form asp-action="Delete" method="post">

    <input type="hidden" asp-for="Id"/>

    <div>
        <p><strong>Mã sinh viên:</strong> @Model.MaSinhVien</p>
        <p><strong>Họ tên:</strong> @Model.HoTen</p>

        <!-- 🔗 thêm hiển thị Khoa -->
        <p><strong>Khoa:</strong> @Model.Khoa?.TenKhoa</p>
    </div>

    <button type="submit" class="btn btn-danger">Xoá</button>
    <a asp-action="Index" class="btn btn-secondary">Huỷ</a>

</form>